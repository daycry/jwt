parameters:
    tmpDir: build/phpstan
    level: 8
    paths:
        - src/
        - tests/
    bootstrapFiles:
        - vendor/codeigniter4/framework/system/Test/bootstrap.php
    excludePaths:
        - tests/_support/*
        - examples/*
    scanDirectories:
        - vendor/codeigniter4/framework/system/Helpers
    universalObjectCratesClasses:
        - CodeIgniter\Entity
        - CodeIgniter\Entity\Entity
    dynamicConstantNames:
        - APP_NAMESPACE
        - CI_DEBUG
        - ENVIRONMENT
        - ROOTPATH
        - APPPATH
        - WRITEPATH
    codeigniter:
        additionalConfigNamespaces:
            - Daycry\JWT\Config\
    ignoreErrors:
        # PHPUnit assertions are static methods used dynamically by convention.
        - identifier: staticMethod.dynamicCall
          path: tests/*
        # PHP 8.5 changed DateTimeImmutable::modify() to throw instead of returning false;
        # the defensive `=== false` checks are still meaningful on PHP 8.2-8.4 so we keep them.
        - identifier: identical.alwaysFalse
          path: src/JWT.php
          reportUnmatched: false

includes:
    - phpstan-baseline.neon
